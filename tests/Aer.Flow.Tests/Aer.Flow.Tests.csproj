<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Generates packages.lock.json so CI can cache NuGet restore (actions/setup-dotnet's
         cache-dependency-path globs **/packages.lock.json, same as Aer.Adapters.Tests). -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Aer.Flow\Aer.Flow.csproj" />
    <!-- M10 Phase 4 (issue #72): shares Aer.Flow.CrashTestHost's Scenarios builder, so this
         project's in-process recovery run binds against the identical WorkflowDefinitionSnapshot
         the killed run used, and locates that project's built assembly (via its Scenarios type's
         own Assembly.Location) to launch it as a real, separate, killable OS process. -->
    <ProjectReference Include="..\Aer.Flow.CrashTestHost\Aer.Flow.CrashTestHost.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- M7 Phase 8's end-to-end test loads a real WorkflowDefinition from disk (issue #14) rather
         than constructing one in-memory, so the fixture must be present next to the test binary. -->
    <None Include="Fixtures\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>