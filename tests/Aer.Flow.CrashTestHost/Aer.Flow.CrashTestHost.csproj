<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- M10 Phase 4 (issue #72): a small, test-only pump host — Aer.Cli is still a stub — that
         Aer.Flow.Tests spawns as a real, separate OS process and kills mid-run to manufacture each
         of §7's crash windows against real Core dispatch, not a stub. Never shipped: lives under
         tests/, referenced only by Aer.Flow.Tests (for the scenario builder, so the killed run and
         the in-process recovery run bind against the identical WorkflowDefinitionSnapshot). -->
    <ProjectReference Include="..\..\src\Aer.Flow\Aer.Flow.csproj" />
  </ItemGroup>

</Project>
