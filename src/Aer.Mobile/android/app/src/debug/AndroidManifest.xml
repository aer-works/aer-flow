<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- M21 Phase 2 (#232): Aer.Daemon serves plain http/ws; TLS is deferred to Phase 6 (see
         docs/decisions-of-record.md, M21). Android blocks cleartext traffic by default for apps targeting
         API 28+, so the first real request would fail with "Cleartext HTTP traffic ... not
         permitted" without this. Scoped to the debug manifest deliberately, matching this
         milestone's debug/sideload-only build (`mobile-build` runs `flutter build apk` with the
         debug flag); a release build must not inherit this silently, revisit when Phase 6
         lands TLS. -->
    <application android:usesCleartextTraffic="true"/>
</manifest>
