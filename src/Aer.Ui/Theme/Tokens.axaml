<!-- M19 Phase 2 (#187): docs/ux/design-language.md's token system, materialized. These are the
     product's identity carried as named resources (the one-product-not-a-collage directive):
     every surface consumes tokens by name — a raw hex value, ad-hoc font size, or magic pixel
     number in a view is a defect from this phase onward. Semantic color only: light and dark are
     two mappings of one system (ThemeDictionaries), never two themes. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- Light -->
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="Color.Background">#F7F8F9</SolidColorBrush>
      <!-- Surface/SurfaceRaised were identical (#FFFFFF/#FFFFFF) — no color step, so nothing read
           as elevated. Base content now sits a hair below pure white; raised surfaces (cards,
           the needs-you callout) keep #FFFFFF and pick up Elevation.Raised/.Overlay's shadow. -->
      <SolidColorBrush x:Key="Color.Surface">#FBFBFC</SolidColorBrush>
      <SolidColorBrush x:Key="Color.SurfaceRaised">#FFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="Color.Border">#D7DBDF</SolidColorBrush>
      <SolidColorBrush x:Key="Color.BorderSubtle">#E8EAEC</SolidColorBrush>
      <SolidColorBrush x:Key="Color.Text">#1A1D21</SolidColorBrush>
      <SolidColorBrush x:Key="Color.TextSecondary">#5B6572</SolidColorBrush>
      <SolidColorBrush x:Key="Color.TextDisabled">#9AA3AD</SolidColorBrush>

      <!-- #216 post-M19 review: Color.Accent moved from a teal that read as "the same green
           family" as Status.Succeeded (41deg apart on the wheel) to a blue-teal (~200deg,
           ~60deg from Succeeded) — distinct at a glance as "primary action" vs. "this succeeded"
           without abandoning the cool, restrained identity design-language.md calls for. -->
      <SolidColorBrush x:Key="Color.Accent">#0E6FA8</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentHover">#0C5F8F</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentPressed">#0A4D74</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBg">#DFEDF5</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgTransparent">#01DFEDF5</SolidColorBrush>
      <SolidColorBrush x:Key="Color.CloseHoverTransparent">#01E81123</SolidColorBrush>
      <SolidColorBrush x:Key="Color.ClosePressedTransparent">#01F1707A</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgPressedTransparent">#010A4D74</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgHoverTransparent">#010C5F8F</SolidColorBrush>

      <!-- Desaturated from the prior stock Tailwind primaries (#2563EB/#B45309/#15803D/#B91C1C/
           #7C3AED) — those read as a generic component-library default, not a considered palette. -->
      <SolidColorBrush x:Key="Status.Running">#4C6C99</SolidColorBrush>
      <SolidColorBrush x:Key="Status.NeedsYou">#A6741F</SolidColorBrush>
      <SolidColorBrush x:Key="Status.NeedsYouBg">#F1E7D2</SolidColorBrush>
      <!-- #216: pushed further toward true/forest green, away from Color.Accent's blue-teal. -->
      <SolidColorBrush x:Key="Status.Succeeded">#2F7A42</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Failed">#A8433D</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Idle">#6B7280</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Stale">#7A6BA3</SolidColorBrush>

      <!-- Status tints (M19 Phase 5, #190): the fill behind a status-colored border — the DAG
           nodes and any surface that carries a status as area rather than line. -->
      <SolidColorBrush x:Key="Status.RunningBg">#E4E9F0</SolidColorBrush>
      <SolidColorBrush x:Key="Status.SucceededBg">#E2ECE4</SolidColorBrush>
      <SolidColorBrush x:Key="Status.FailedBg">#F1E3E1</SolidColorBrush>
      <SolidColorBrush x:Key="Status.IdleBg">#F0F1F3</SolidColorBrush>
      <SolidColorBrush x:Key="Status.StaleBg">#E9E5EF</SolidColorBrush>

      <!-- Elevation (design-language.md's shape/depth section): shadow + the Surface/SurfaceRaised
           color step above. Light leans on both shadow and the color step. -->
      <BoxShadows x:Key="Elevation.Flat">0 0 0 0 Transparent</BoxShadows>
      <BoxShadows x:Key="Elevation.Raised">0 1 3 0 #221A1D21</BoxShadows>
      <BoxShadows x:Key="Elevation.Overlay">0 4 16 0 #331A1D21</BoxShadows>
    </ResourceDictionary>

    <!-- Dark: same system, second mapping. Depth leans on surface steps, not shadows. -->
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="Color.Background">#15171B</SolidColorBrush>
      <SolidColorBrush x:Key="Color.Surface">#1D2025</SolidColorBrush>
      <SolidColorBrush x:Key="Color.SurfaceRaised">#25292F</SolidColorBrush>
      <SolidColorBrush x:Key="Color.Border">#343A42</SolidColorBrush>
      <SolidColorBrush x:Key="Color.BorderSubtle">#2A2F36</SolidColorBrush>
      <SolidColorBrush x:Key="Color.Text">#E8EAED</SolidColorBrush>
      <SolidColorBrush x:Key="Color.TextSecondary">#9BA3AE</SolidColorBrush>
      <SolidColorBrush x:Key="Color.TextDisabled">#5D656F</SolidColorBrush>

      <!-- #216: same blue-teal shift as light — see that dictionary's comment. -->
      <SolidColorBrush x:Key="Color.Accent">#3B9FD6</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentHover">#57B3E8</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentPressed">#2C86BA</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBg">#17293A</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgTransparent">#0117293A</SolidColorBrush>
      <SolidColorBrush x:Key="Color.CloseHoverTransparent">#01E81123</SolidColorBrush>
      <SolidColorBrush x:Key="Color.ClosePressedTransparent">#01F1707A</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgPressedTransparent">#012C86BA</SolidColorBrush>
      <SolidColorBrush x:Key="Color.AccentSubtleBgHoverTransparent">#0157B3E8</SolidColorBrush>

      <SolidColorBrush x:Key="Status.Running">#6E93C2</SolidColorBrush>
      <SolidColorBrush x:Key="Status.NeedsYou">#C9A15C</SolidColorBrush>
      <SolidColorBrush x:Key="Status.NeedsYouBg">#332C1E</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Succeeded">#4CAE68</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Failed">#C97F79</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Idle">#9CA3AF</SolidColorBrush>
      <SolidColorBrush x:Key="Status.Stale">#9684C4</SolidColorBrush>

      <SolidColorBrush x:Key="Status.RunningBg">#1E2836</SolidColorBrush>
      <SolidColorBrush x:Key="Status.SucceededBg">#1E2A22</SolidColorBrush>
      <SolidColorBrush x:Key="Status.FailedBg">#302321</SolidColorBrush>
      <SolidColorBrush x:Key="Status.IdleBg">#22262C</SolidColorBrush>
      <SolidColorBrush x:Key="Status.StaleBg">#26222E</SolidColorBrush>

      <!-- Elevation: dark leans on the Surface/SurfaceRaised color step alone (already distinct
           here) — a shadow barely reads against a near-black background, per the file header's
           existing "depth leans on surface steps, not shadows" convention. -->
      <BoxShadows x:Key="Elevation.Flat">0 0 0 0 Transparent</BoxShadows>
      <BoxShadows x:Key="Elevation.Raised">0 0 0 0 Transparent</BoxShadows>
      <BoxShadows x:Key="Elevation.Overlay">0 4 16 0 #4D000000</BoxShadows>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- Type scale (Inter is the app default family via WithInterFont; mono for artifact/transcript content) -->
  <x:Double x:Key="Type.Display.FontSize">24</x:Double>
  <x:Double x:Key="Type.Heading.FontSize">17</x:Double>
  <x:Double x:Key="Type.Body.FontSize">14</x:Double>
  <!-- Emphasis within body — step names, labels — never the same weight as a heading. -->
  <x:Double x:Key="Type.BodyStrong.FontSize">14</x:Double>
  <x:Double x:Key="Type.Caption.FontSize">12</x:Double>
  <x:Double x:Key="Type.Mono.FontSize">13</x:Double>
  <FontFamily x:Key="Type.Mono.FontFamily">Cascadia Mono,Consolas,Menlo,monospace</FontFamily>

  <!-- 4px spacing grid -->
  <x:Double x:Key="Space.1">4</x:Double>
  <x:Double x:Key="Space.2">8</x:Double>
  <x:Double x:Key="Space.3">12</x:Double>
  <x:Double x:Key="Space.4">16</x:Double>
  <x:Double x:Key="Space.5">20</x:Double>
  <x:Double x:Key="Space.6">24</x:Double>
  <x:Double x:Key="Space.8">32</x:Double>

  <!-- Shape: two radii, no rounded-rectangle zoo -->
  <CornerRadius x:Key="Radius.Small">4</CornerRadius>
  <CornerRadius x:Key="Radius.Medium">8</CornerRadius>

  <!-- Motion durations (milliseconds) — consumed by Phase 5's animations; named now so nothing invents its own -->
  <x:Double x:Key="Motion.Fast">120</x:Double>
  <x:Double x:Key="Motion.Base">200</x:Double>
  <x:Double x:Key="Motion.Slow">320</x:Double>

  <!-- Vendor identity (M22 template picker): brand marks, not a semantic status, so — like Space/Type
       above — one constant mapping outside ThemeDictionaries rather than a light/dark pair. -->
  <SolidColorBrush x:Key="Vendor.Claude">#D97757</SolidColorBrush>
  <SolidColorBrush x:Key="Vendor.Gemini">#4285F4</SolidColorBrush>

</ResourceDictionary>
