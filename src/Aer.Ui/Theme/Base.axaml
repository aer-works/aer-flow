<!-- M19 Phase 2 (#187) grew this as the "nothing ships default-themed" floor; Phase 5 (#190)
     makes it the custom control theme over FluentTheme: every stock control re-skinned to the
     token system (design-language.md), with motion as short brush transitions — confirm, don't
     perform. Everything here consumes Tokens.axaml by name; a raw value is a defect. -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Color.Background}" />
    <Setter Property="Foreground" Value="{DynamicResource Color.Text}" />
    <Setter Property="FontSize" Value="{DynamicResource Type.Body.FontSize}" />
  </Style>

  <!-- Text roles -->
  <Style Selector="TextBlock.display">
    <Setter Property="FontSize" Value="{DynamicResource Type.Display.FontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.heading">
    <Setter Property="FontSize" Value="{DynamicResource Type.Heading.FontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="{DynamicResource Type.Caption.FontSize}" />
    <Setter Property="Foreground" Value="{DynamicResource Color.TextSecondary}" />
  </Style>

  <!-- Emphasis within body text — step names, card titles, labels. Distinct from heading's larger
       size and SemiBold; everything doing emphasis was using heading's weight ad hoc before this,
       which is why text read as uniformly flat regardless of its actual role. -->
  <Style Selector="TextBlock.body-strong">
    <Setter Property="FontSize" Value="{DynamicResource Type.BodyStrong.FontSize}" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="TextBlock.secondary">
    <Setter Property="Foreground" Value="{DynamicResource Color.TextSecondary}" />
  </Style>

  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="{DynamicResource Type.Mono.FontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource Type.Mono.FontSize}" />
  </Style>

  <!-- Stock controls, re-skinned to the tokens (Phase 5). Property-level restyling over
       FluentTheme's templates — the shapes are fine, the identity comes from color/radius. -->
  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource Color.Surface}" />
    <Setter Property="Foreground" Value="{DynamicResource Color.Text}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <!-- Radius.Medium, not .Small: the owner's "round buttons more" feedback — reuses the same
         two-radii budget the cards already sit on rather than inventing a third radius. -->
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="14,7" />
  </Style>
  <Style Selector="Button /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Accent}" />
    <Setter Property="Foreground" Value="{DynamicResource Color.Text}" />
  </Style>
  <Style Selector="Button:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.AccentPressed}" />
  </Style>

  <!-- The one loud button per surface: Run / Save and run / Approve -->
  <Style Selector="Button.accent">
    <Setter Property="Background" Value="{DynamicResource Color.Accent}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Accent}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentHover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.AccentHover}" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.accent:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentPressed}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.AccentPressed}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource Color.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Border}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Accent}" />
  </Style>

  <Style Selector="TextBox.mono">
    <Setter Property="FontFamily" Value="{DynamicResource Type.Mono.FontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource Type.Mono.FontSize}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource Color.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Border}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
  </Style>

  <Style Selector="Expander">
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="FontSize" Value="{DynamicResource Type.Body.FontSize}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="36" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- A card: the surface unit Home's task cards and inbox items are built from. SurfaceRaised +
       Elevation.Raised (not the page's own Color.Surface) is what makes a card read as a distinct,
       lifted object rather than a flat-colored rectangle sitting on the same plane as the page. -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource Color.SurfaceRaised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <!-- Space.4 (16px) — Thickness properties can't consume the double-typed Space.* tokens
         through DynamicResource (no implicit conversion at runtime; throws InvalidCastException),
         so the value is inlined here instead of tokenized. -->
    <Setter Property="Padding" Value="16" />
    <Setter Property="BoxShadow" Value="{DynamicResource Elevation.Raised}" />
  </Style>

  <!-- The attention card: Status.NeedsYou is the loudest thing in the system (ux-principles §4) —
       Elevation.Overlay gives it more lift than an ordinary card, on top of its border/fill. -->
  <Style Selector="Border.card.needs-you">
    <Setter Property="BorderBrush" Value="{DynamicResource Status.NeedsYou}" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="Background" Value="{DynamicResource Status.NeedsYouBg}" />
    <Setter Property="BoxShadow" Value="{DynamicResource Elevation.Overlay}" />
  </Style>

  <!-- A clickable card (Home's task cards, the step chips). BoxShadow lives on Button, not
       Border, so it targets the template's ContentPresenter, same as the hover/pressed setters
       below already do for Background/BorderBrush. -->
  <Style Selector="Button.card">
    <Setter Property="Background" Value="{DynamicResource Color.SurfaceRaised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <!-- Space.4 (16px) — Thickness properties can't consume the double-typed Space.* tokens
         through DynamicResource (no implicit conversion at runtime; throws InvalidCastException),
         so the value is inlined here instead of tokenized. -->
    <Setter Property="Padding" Value="16" />
  </Style>
  <Style Selector="Button.card /template/ ContentPresenter">
    <Setter Property="BoxShadow" Value="{DynamicResource Elevation.Raised}" />
  </Style>
  <Style Selector="Button.card.selected">
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Accent}" />
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
  </Style>
  <Style Selector="Button.card:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Color.Accent}" />
  </Style>

  <!-- The navigation rail: quiet buttons, accent only on the active section -->
  <Style Selector="Button.nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Color.TextSecondary}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="12,8" />
  </Style>
  <Style Selector="Button.nav.selected">
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
    <Setter Property="Foreground" Value="{DynamicResource Color.Accent}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Color.AccentSubtleBg}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

</Styles>
