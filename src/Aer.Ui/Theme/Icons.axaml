<!-- M19 post-milestone design review (issue #206): design-language.md's status table specifies an
     icon per status ("color + icon + word, never color alone" — TaskCardViewModel's own comment
     said as much and nothing consumed it). One geometry set, drawn by hand at a 16x16 grid so
     every status icon shares stroke weight and proportion — status is told by shape, color is
     reinforcement, not the only signal. Stroke-based (Path, not PathIcon) so line glyphs
     (check/cross/ring) don't need a closed fill area. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Succeeded: checkmark -->
  <StreamGeometry x:Key="Icon.Check">M 3,8.5 L 6.5,12 L 13,4</StreamGeometry>

  <!-- Failed: cross -->
  <StreamGeometry x:Key="Icon.Cross">M 4,4 L 12,12 M 12,4 L 4,12</StreamGeometry>

  <!-- Idle (hollow) / NeedsYou (filled) — one circle, two fill treatments at the call site. -->
  <StreamGeometry x:Key="Icon.Dot">M 13,8 A 5,5 0 1 1 3,8 A 5,5 0 1 1 13,8 Z</StreamGeometry>

  <!-- Running: an open ring — the static frame of a spinner (no motion in this pass, #208 owns animation). -->
  <StreamGeometry x:Key="Icon.Ring">M 8,3 A 5,5 0 1 1 3.66,10.5</StreamGeometry>

  <!-- Stale: a ring left open with a small arrow tick — the refresh mark. -->
  <StreamGeometry x:Key="Icon.Refresh">M 12.8,5.2 A 5,5 0 1 0 13,8 M 13,8 L 13,5.3 M 13,8 L 10.3,7.3</StreamGeometry>

  <!-- #218: navigation rail + common actions, same 16x16 hand-drawn stroke set as the status
       icons above — Approve reuses Icon.Check and Reject reuses Icon.Cross (the issue's own
       "approve/check", "reject/cross" pairing); Retry reuses Icon.Refresh (an "again" arrow
       already exists, no need for a near-duplicate). Only the four genuinely new glyphs live
       here: Home, Task, Author, and Folder (the picker button, #212). -->
  <StreamGeometry x:Key="Icon.Home">M 2,8 L 8,2.5 L 14,8 M 4,6.8 L 4,13 L 12,13 L 12,6.8</StreamGeometry>

  <!-- A checklist — three list lines, the last one shorter (owner feedback: both the original
       two-circles-and-a-diagonal draft *and* the flowchart-node draft that replaced it still read
       as an old telephone handset at 14x14 — a branching-node glyph reads as a graph only at a
       size big enough to show its joints, which this rail icon isn't. A list needs no such
       resolution, and "task" maps to "item on a list" as directly as "author" maps to a pencil. -->
  <StreamGeometry x:Key="Icon.Task">M 3,4 L 13,4 M 3,8 L 13,8 M 3,12 L 9,12</StreamGeometry>

  <!-- A pencil — authoring. -->
  <StreamGeometry x:Key="Icon.Author">M 3,13 L 3.8,10.2 L 10.3,3.7 L 12.3,5.7 L 5.8,12.2 Z M 9.1,4.9 L 11.1,6.9</StreamGeometry>

  <!-- A folder — the browse/open action. -->
  <StreamGeometry x:Key="Icon.Folder">M 2,5.5 L 6,5.5 L 7.3,7 L 14,7 L 14,12.5 L 2,12.5 Z</StreamGeometry>

  <!-- A broadcast/signal glyph — Remote nav destination (M21 Phase 3, #234): a dot with two arcs, the standard "wireless" pictogram. -->
  <StreamGeometry x:Key="Icon.Remote">M 8,12.5 A 0.6,0.6 0 1 1 7.99,12.5 M 5.3,10 A 4,4 0 0 1 10.7,10 M 3,7.7 A 7.5,7.5 0 0 1 13,7.7</StreamGeometry>

  <!-- M22 template-picker vendor icons (issue #250 review follow-up): closed, fillable shapes (same
       16x16 grid as the set above), each a distinct point-count silhouette so the two read apart
       even without color. Claude: a 6-point sunburst. Gemini: a 4-point sparkle/diamond — fewer,
       fatter points than Claude's, deliberately, so shape alone (not just brand color) tells them
       apart. Neither reproduces the real vendor mark; both are original abstractions. -->
  <StreamGeometry x:Key="Icon.Vendor.Claude">M 8,2 L 9.2,5.9 L 13.2,5 L 10.4,8 L 13.2,11 L 9.2,10.1 L 8,14 L 6.8,10.1 L 2.8,11 L 5.6,8 L 2.8,5 L 6.8,5.9 Z</StreamGeometry>
  <StreamGeometry x:Key="Icon.Vendor.Gemini">M 8,1.5 L 9.4,6.6 L 14.5,8 L 9.4,9.4 L 8,14.5 L 6.6,9.4 L 1.5,8 L 6.6,6.6 Z</StreamGeometry>

</ResourceDictionary>
