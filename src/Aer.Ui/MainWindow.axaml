<!-- M19 Phase 2 (#187): the navigation shell — docs/ux/information-architecture.md's flat
     three-destination navigation over the re-homed views. All views stay instantiated (visibility
     toggled), so control state and test round trips survive navigation exactly as they survived
     scrolling in the single stacked window this replaces. -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
        xmlns:views="clr-namespace:Aer.Ui.Views"
        x:Class="Aer.Ui.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AER Flow"
        Width="960" Height="720">
  <DockPanel>
    <Border DockPanel.Dock="Left" Background="{DynamicResource Color.Surface}"
            BorderBrush="{DynamicResource Color.BorderSubtle}" BorderThickness="0,0,1,0">
      <StackPanel Margin="8" Spacing="4" Width="120">
        <Button x:Name="NavHomeButton" Content="Home" HorizontalAlignment="Stretch" />
        <Button x:Name="NavTaskButton" Content="Task" HorizontalAlignment="Stretch" />
        <Button x:Name="NavAuthorButton" Content="Author" HorizontalAlignment="Stretch" />
      </StackPanel>
    </Border>
    <Panel>
      <views:HomeView x:Name="HomeViewControl" IsVisible="{Binding IsHomeVisible}" />
      <views:TaskView x:Name="TaskViewControl" IsVisible="{Binding IsTaskVisible}" />
      <views:AuthorView x:Name="AuthorViewControl" IsVisible="{Binding IsAuthorVisible}" />
    </Panel>
  </DockPanel>
</Window>
