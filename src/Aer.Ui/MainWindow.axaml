<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Aer.Ui"
        x:Class="Aer.Ui.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AER Flow UI"
        Width="720" Height="640">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="TaskDirectoryPathBox" Width="480" PlaceholderText="Task directory path" />
        <Button x:Name="OpenButton" Content="Open" />
        <Button x:Name="RefreshButton" Content="Refresh" />
      </StackPanel>

      <TextBlock Text="Recent task directories:" FontWeight="Bold" />
      <StackPanel x:Name="RecentsPanel" Spacing="4" />

      <TextBlock Text="Run (start a fresh task, or resume the task directory above after a pause or stop):" FontWeight="Bold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="WorkflowTemplatePathBox" Width="300" PlaceholderText="Workflow template file (fresh start only)" />
        <TextBox x:Name="BindingsFilePathBox" Width="300" PlaceholderText="Worker-bindings file" />
        <Button x:Name="RunButton" Content="Run" IsEnabled="{Binding !IsMutationInFlight}" />
        <Button x:Name="StopButton" Content="Stop" ToolTip.Tip="Cancel every execution this window currently has in flight (§9 host stop)." />
      </StackPanel>
      <TextBlock x:Name="RunStatusText" />

      <TextBlock Text="Template editor (create or edit a template file — never a bound task, §5):" FontWeight="Bold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="TemplateEditorPathBox" Width="360" PlaceholderText="Template file to edit / save to" />
        <Button x:Name="NewTemplateButton" Content="New template" />
        <Button x:Name="EditTemplateButton" Content="Open in editor" />
        <Button x:Name="SaveTemplateButton" Content="Save" IsEnabled="{Binding TemplateEditor.IsDirty}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Text="{Binding TemplateEditor.TemplateId}" Width="300"
                 PlaceholderText="WorkflowTemplateId" IsEnabled="{Binding TemplateEditor.IsOpen}" />
        <TextBox Text="{Binding TemplateEditor.TemplateVersionText}" Width="120"
                 PlaceholderText="Version" IsEnabled="{Binding TemplateEditor.IsOpen}" />
      </StackPanel>
      <TextBlock x:Name="TemplateEditorStatusText" Text="{Binding TemplateEditor.StatusText}" />

      <TextBlock x:Name="StatusText" FontWeight="Bold" Text="No task directory loaded." />
      <StackPanel x:Name="StepsPanel" Spacing="4" />

      <TextBlock Text="Running / pending executions — cancel (§7):" FontWeight="Bold" />
      <ItemsControl x:Name="RunningExecutionsList" ItemsSource="{Binding RunningExecutions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:RunningExecutionViewModel">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Label}" Width="280" VerticalAlignment="Center" />
              <Button Content="Cancel" Command="{Binding CancelCommand}" />
              <TextBlock Text="cancellation requested…" IsVisible="{Binding CancellationRequested}" VerticalAlignment="Center" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="CancelStatusText" Text="{Binding CancelStatusText}" />

      <TextBlock Text="Paused steps — decide (§7's Approve/Reject/Retry/Send back):" FontWeight="Bold" />
      <ItemsControl x:Name="PausedStepsList" ItemsSource="{Binding PausedSteps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PausedStepViewModel">
            <StackPanel Spacing="4" Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Label}" Width="280" VerticalAlignment="Center" />
                <Button Content="Approve" Command="{Binding ApproveCommand}" />
                <Button Content="Reject" Command="{Binding RejectCommand}" />
                <Button Content="Retry" Command="{Binding RetryCommand}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding RevisionFilePath}" Width="240"
                         PlaceholderText="Revision file (optional for Retry, required to send back)" />
                <TextBox Text="{Binding SupplementaryWorker}" Width="110" PlaceholderText="Worker role" />
                <TextBox Text="{Binding SupplementaryOutputName}" Width="110" PlaceholderText="Output name" />
              </StackPanel>
              <ItemsControl ItemsSource="{Binding SendBackTargets}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SendBackTargetViewModel">
                    <Button Content="{Binding Label}" Command="{Binding SendBackCommand}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="DecisionStatusText" Text="{Binding DecisionStatusText}" />

      <TextBlock Text="Workflow graph:" FontWeight="Bold" />
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="360">
        <Canvas x:Name="DagCanvas" />
      </ScrollViewer>

      <TextBlock Text="Execution history:" FontWeight="Bold" />
      <StackPanel x:Name="HistoryPanel" Spacing="2" />

      <TextBlock Text="Recorded decisions:" FontWeight="Bold" />
      <StackPanel x:Name="DecisionsPanel" Spacing="2" />

      <TextBlock Text="Supplementary / human executions:" FontWeight="Bold" />
      <StackPanel x:Name="SupplementaryPanel" Spacing="2" />

      <TextBlock Text="Artifact lineage:" FontWeight="Bold" />
      <StackPanel x:Name="LineagePanel" Spacing="6" />

      <TextBlock Text="Artifact preview:" FontWeight="Bold" />
      <TextBox x:Name="ArtifactPreviewBox" IsReadOnly="True" AcceptsReturn="True"
               TextWrapping="Wrap" Height="140" FontFamily="Consolas,monospace" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="TemplateComparePathBox" Width="480" PlaceholderText="Template path to compare against (optional)" />
        <Button x:Name="CompareButton" Content="Compare to template" />
      </StackPanel>
      <TextBlock Text="Snapshot vs. template diff:" FontWeight="Bold" />
      <StackPanel x:Name="DiffPanel" Spacing="2" />
    </StackPanel>
  </ScrollViewer>
</Window>
