<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Aer.Ui.Converters"
             x:Class="Aer.Ui.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- M19 Phase 2 (#187): the design-language token system — every surface consumes these by name -->
        <ResourceInclude Source="/Theme/Tokens.axaml" />
        <!-- Post-M19 design review (#206): status icon geometries -->
        <ResourceInclude Source="/Theme/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <conv:StatusToIconGeometryConverter x:Key="StatusToIconGeometryConverter" />
      <conv:StatusToIconBrushConverter x:Key="StatusToIconBrushConverter" />
      <conv:VendorIconGeometryConverter x:Key="VendorIconGeometryConverter" />
      <conv:VendorIconBrushConverter x:Key="VendorIconBrushConverter" />
      <conv:ByteArrayToBitmapConverter x:Key="ByteArrayToBitmapConverter" />
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="/Theme/Base.axaml" />
  </Application.Styles>
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/aer.ico" ToolTipText="AER Flow">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Show AER Flow" Click="MenuShow_Click" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Click="MenuExit_Click" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
