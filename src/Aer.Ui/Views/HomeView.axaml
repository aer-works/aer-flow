<!-- M19 Phase 2 (#187): Home — the screen that answers "what needs me?" in one glance
     (docs/ux/information-architecture.md). Decision inbox first, task cards second, the
     open-a-folder fallback last: cards are the path, picking is the fallback. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.HomeView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <!-- Hierarchical spacing (owner feedback, post-M19 review): Space.8 between sections — each
         its own visual group — Space.2/.3 within a section, so the gap itself carries structure
         instead of one flat rhythm from page title down to the last button. -->
    <!-- Space.6 (24px) inlined for Margin — DynamicResource can't cross double->Thickness. -->
    <StackPanel Margin="24" Spacing="{DynamicResource Space.8}" MaxWidth="760" HorizontalAlignment="Left">
      <TextBlock Classes="display" Text="Home" />

      <StackPanel Spacing="{DynamicResource Space.3}">
      <TextBlock Classes="heading" Text="Waiting on you" />
      <TextBlock x:Name="InboxSummaryText" Classes="secondary" Text="{Binding Home.InboxSummaryText}" />
      <ItemsControl x:Name="InboxList" ItemsSource="{Binding Home.InboxItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:InboxItemViewModel">
            <Border Classes="card needs-you" Margin="0,0,0,8">
              <StackPanel Spacing="{DynamicResource Space.3}">
                <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                  <!-- Every inbox item is a paused step by construction — the filled dot is the
                       one status this list ever shows (design-language.md's icon table). -->
                  <Path Data="{StaticResource Icon.Dot}" Fill="{DynamicResource Status.NeedsYou}"
                        Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                  <TextBlock Classes="body-strong" Text="{Binding TaskTitle}" />
                  <TextBlock Classes="secondary" Text="{Binding StepName}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" />
                <TextBlock Classes="mono" Text="{Binding PreviewText}" TextWrapping="Wrap"
                           IsVisible="{Binding HasPreview}" MaxHeight="180" />
                <Button Classes="accent" Content="Review" Command="{Binding ReviewCommand}" HorizontalAlignment="Left" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      </StackPanel>

      <StackPanel Spacing="{DynamicResource Space.3}">
      <TextBlock Classes="heading" Text="Tasks" />
      <!-- The empty state says what to do next (Phase 5): first run, no history yet. -->
      <Border Classes="card" IsVisible="{Binding Home.HasNoTasks}">
        <StackPanel Spacing="{DynamicResource Space.2}">
          <TextBlock Classes="body-strong" Text="No tasks yet." />
          <TextBlock Classes="secondary" TextWrapping="Wrap"
                     Text="Create a workflow and run it — or open an existing task folder below." />
          <Button x:Name="CreateWorkflowButton" Classes="accent"
                  HorizontalAlignment="Left" Click="OnCreateWorkflowClick">
            <AccessText Text="_Create a workflow" />
          </Button>
        </StackPanel>
      </Border>
      <ItemsControl x:Name="TaskCardsList" ItemsSource="{Binding Home.TaskCards}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TaskCardViewModel">
            <Button Classes="card" Command="{Binding OpenCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,8">
              <StackPanel Spacing="{DynamicResource Space.1}">
                <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                  <Path Data="{Binding Status, Converter={StaticResource StatusToIconGeometryConverter}}"
                        Stroke="{Binding Status, Converter={StaticResource StatusToIconBrushConverter}}"
                        StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                        Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" />
                  <TextBlock Classes="body-strong" Text="{Binding Title}" />
                </StackPanel>
                <TextBlock Classes="secondary" Text="{Binding StatusText}" />
                <TextBlock Classes="caption" Text="{Binding TaskDirectoryPath}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      </StackPanel>

      <StackPanel Spacing="{DynamicResource Space.3}">
      <TextBlock Classes="heading" Text="Open a task" />
      <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
        <TextBox x:Name="TaskDirectoryPathBox" Width="480" PlaceholderText="Task directory path" />
        <Button x:Name="OpenButton"><AccessText Text="_Open" /></Button>
        <Button x:Name="RefreshButton"><AccessText Text="Re_fresh" /></Button>
      </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
