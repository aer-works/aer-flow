<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Aer.Ui.Views.TemplatePickerWindow"
        Title="Start from Template"
        Width="540" Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Window.Resources>
    <!-- M22 review follow-up (issue #250): vendor CLI dropdown items get the same icon+brand-color
         treatment as the task view's step chips, via the shared VendorIcon*Converter pair — one
         mapping, every surface, per design-language.md. Items are plain adapter-name strings. -->
    <DataTemplate x:Key="VendorComboItemTemplate" x:DataType="x:String">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Path Data="{Binding Converter={StaticResource VendorIconGeometryConverter}}"
              Fill="{Binding Converter={StaticResource VendorIconBrushConverter}}"
              Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" />
        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>
  </Window.Resources>
  <Border Padding="24">
    <StackPanel Spacing="16">
      <TextBlock Classes="heading" Text="Start from a Workflow Template" FontSize="18" FontWeight="Bold" />
      <TextBlock Classes="secondary" Text="Select a pre-authored template shape and choose vendor CLI options." TextWrapping="Wrap" />

      <StackPanel Spacing="8">
        <TextBlock Classes="body-strong" Text="Workflow Template:" />
        <RadioButton x:Name="SoloRunRadio" Content="Solo Run — Single-step execution (Claude or Gemini)" IsChecked="True" GroupName="TemplateGroup" IsCheckedChanged="OnTemplateChanged" />
        <RadioButton x:Name="ReviewRunRadio" Content="Review Run — Two-step Draft → Human Review" GroupName="TemplateGroup" IsCheckedChanged="OnTemplateChanged" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="body-strong" Text="Task Name (Optional):" />
        <TextBox x:Name="TaskNameBox" PlaceholderText="e.g. my-first-solo-run" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="body-strong" Text="Custom Initial Prompt (Optional):" />
        <TextBox x:Name="CustomPromptBox" PlaceholderText="e.g. Write a summary of AI agent architecture" AcceptsReturn="True" Height="60" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="body-strong" Text="Primary Worker CLI Vendor:" />
        <ComboBox x:Name="PrimaryVendorCombo" HorizontalAlignment="Stretch" ItemTemplate="{StaticResource VendorComboItemTemplate}" />
      </StackPanel>

      <StackPanel x:Name="SecondaryVendorPanel" Spacing="8" IsVisible="False">
        <TextBlock Classes="body-strong" Text="Reviewer Worker CLI Vendor:" />
        <ComboBox x:Name="SecondaryVendorCombo" HorizontalAlignment="Stretch" ItemTemplate="{StaticResource VendorComboItemTemplate}" />
        <TextBlock Classes="body-strong" Text="Reviewer's Instructions (Optional):" />
        <TextBox x:Name="SecondaryCustomPromptBox" PlaceholderText="e.g. Write your own roast back, don't critique the draft as a document" AcceptsReturn="True" Height="60" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,12,0,0">
        <Button Content="Cancel" Click="OnCancelClick" />
        <Button Classes="accent" Content="Start Task" Click="OnStartClick" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
