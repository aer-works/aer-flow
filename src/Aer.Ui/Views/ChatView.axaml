<!-- M24 Phase 1 desktop chat UI (issue #262): a dedicated view for interactive chat/codebase
     sessions instead of the generic Task view's DAG drill-in — a single repeatedly-superseded
     "chat" step has no dependency graph worth showing, and the real content
     (SessionMetadata.Turns) lives outside TaskProjection entirely (see ChatViewModel's remarks). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.ChatView"
             x:DataType="vm:MainWindowViewModel">
  <DockPanel Margin="24">
    <TextBlock DockPanel.Dock="Top" Classes="display" Text="{Binding Chat.HeadlineText}" />

    <!-- Persistent mode indicator (#286): mode buttons live in the collapsed Commands panel below,
         but the currently active mode was previously invisible until you reopened that panel and
         happened to remember which button you last clicked. -->
    <TextBlock DockPanel.Dock="Top" Classes="caption secondary" Margin="0,2,0,0"
               Text="{Binding Chat.CurrentMode, StringFormat='Mode: {0}'}"
               IsVisible="{Binding Chat.HasCurrentMode}" />

    <TextBlock DockPanel.Dock="Top" Classes="secondary" Foreground="{DynamicResource Status.Failed}"
               TextWrapping="Wrap" Text="{Binding Chat.StatusText}"
               IsVisible="{Binding Chat.HasStatusText}" />

    <StackPanel DockPanel.Dock="Bottom" Spacing="{DynamicResource Space.2}" Margin="0,12,0,0">
      <!-- The raw in-turn stream — plain text for now (Kind-based rendering, e.g. distinguishing
           tool calls from prose, is visual polish left for M25). -->
      <Border Classes="card" IsVisible="{Binding Chat.IsSending}" MaxHeight="140">
        <ScrollViewer>
          <TextBlock Classes="mono caption" TextWrapping="Wrap" Text="{Binding Chat.LiveProgressText}" />
        </ScrollViewer>
      </Border>
      <!-- Chat capability picker (M24 Phase 2 follow-up): recently-used skills/commands/agents
           first, an informational-only section for modes/plugins that aren't chat-invokable, plus
           session-level mode buttons applying to whichever vendor is currently active. -->
      <Border Classes="card" IsVisible="{Binding Chat.IsCommandMenuOpen}" MaxHeight="220">
        <ScrollViewer>
          <StackPanel Spacing="{DynamicResource Space.2}">
            <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.1}">
              <TextBlock Classes="caption body-strong" Text="Mode" VerticalAlignment="Center" />
              <Button x:Name="ChatModeAutoButton" Content="Auto" />
              <Button x:Name="ChatModeDefaultButton" Content="Default" />
              <Button x:Name="ChatModePlanButton" Content="Plan (read-only)" />
            </StackPanel>
            <ItemsControl x:Name="ChatCommandsList" ItemsSource="{Binding Chat.InvokableCommands}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatCapabilityItemViewModel">
                  <Button Classes="ghost" HorizontalContentAlignment="Left" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.1}">
                      <TextBlock Classes="body-strong" Text="{Binding Name}" />
                      <TextBlock Classes="caption secondary" Text="{Binding Description}" />
                      <TextBlock Classes="caption" Text="recent" IsVisible="{Binding IsRecentlyUsed}" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding Chat.InfoCommands}" IsVisible="{Binding Chat.InfoCommands.Count}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatCapabilityItemViewModel">
                  <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.1}">
                    <TextBlock Classes="caption secondary" Text="{Binding Name}" />
                    <TextBlock Classes="caption secondary" Text="{Binding Description}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>
      <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}"
                  IsVisible="{Binding Chat.IsSessionOpen}">
        <TextBox x:Name="ChatInputBox" Width="600" AcceptsReturn="True" MaxHeight="80"
                 Text="{Binding Chat.InputText}" IsEnabled="{Binding !Chat.IsSending}"
                 PlaceholderText="Message..." />
        <Button x:Name="ChatSendButton" Classes="accent" Content="Send"
                IsEnabled="{Binding !Chat.IsSending}" />
        <Button x:Name="ChatCommandsButton" Content="Commands" />
        <ProgressBar IsIndeterminate="True" Width="20" Height="20" VerticalAlignment="Center"
                     IsVisible="{Binding Chat.IsSending}" />
      </StackPanel>

      <!-- "Start new chat" entry point (#290): no dependency on the template picker, which forced
           picking through five unrelated template kinds (review-run, solo-run, ...) just to start a
           plain chat. Working directory is optional — omitting it starts a plain chat session, same
           as the template picker's own "chat session" option with no project directory set. -->
      <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}"
                  IsVisible="{Binding !Chat.IsSessionOpen}">
        <ComboBox x:Name="ChatNewAdapterCombo" Width="140"
                  ItemsSource="{Binding Chat.AvailableAdapters}"
                  SelectedItem="{Binding Chat.NewChatAdapter}"
                  IsEnabled="{Binding !Chat.IsStartingNewChat}" />
        <TextBox x:Name="ChatNewWorkingDirectoryBox" Width="360"
                 Text="{Binding Chat.NewChatWorkingDirectory}"
                 IsEnabled="{Binding !Chat.IsStartingNewChat}"
                 PlaceholderText="Working directory (optional — plain chat if empty)" />
        <Button x:Name="ChatStartNewButton" Classes="accent" Content="Start new chat"
                IsEnabled="{Binding !Chat.IsStartingNewChat}" />
        <ProgressBar IsIndeterminate="True" Width="20" Height="20" VerticalAlignment="Center"
                     IsVisible="{Binding Chat.IsStartingNewChat}" />
      </StackPanel>
    </StackPanel>

    <ScrollViewer x:Name="ChatMessagesScroll">
      <ItemsControl x:Name="ChatMessagesList" ItemsSource="{Binding Chat.Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ChatMessageViewModel">
            <Border Classes="card" Margin="0,0,0,8">
              <StackPanel Spacing="{DynamicResource Space.1}">
                <TextBlock Classes="caption body-strong" Text="{Binding SenderLabel}" />
                <TextBlock Classes="secondary" TextWrapping="Wrap" Text="{Binding Text}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
