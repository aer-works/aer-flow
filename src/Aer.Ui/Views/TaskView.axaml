<!-- M19 Phase 3 (#188): the Task view rebuilt human-first — needs-you first (inline decisions),
     then the DAG as the primary surface with per-step drill-in tabs (attempts / outputs /
     conversation / decisions), plain-language vocabulary throughout the primary text. The precise,
     complete engine-level record stays one disclosure away in the Details expander (§12
     traceability; ux-principles' progressive disclosure). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.TaskView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Classes="display" Text="{Binding TaskHeadlineText}" />
      <!-- The empty state says what to do next (Phase 5): nothing open, two ways forward. -->
      <TextBlock Classes="secondary" IsVisible="{Binding !HasSelectedStep}" TextWrapping="Wrap"
                 Text="Open a task from Home, or create and run a workflow in Author — this view fills in as soon as a task is open." />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Workflow:" VerticalAlignment="Center" />
        <TextBox x:Name="WorkflowTemplatePathBox" Width="300" PlaceholderText="Workflow file (fresh start only)" />
        <TextBlock Text="Bindings:" VerticalAlignment="Center" />
        <TextBox x:Name="BindingsFilePathBox" Width="300"
                 PlaceholderText="Who runs each step (bindings file)"
                 ToolTip.Tip="Who runs each step — always visible, always swappable, never remembered as authority." />
        <!-- Owner feedback: "does Run make sense on a finished task?" — disabled once the open
             task has actually finished, rather than leaving a click that quietly does nothing. -->
        <Button x:Name="RunButton" Classes="accent" IsEnabled="{Binding CanRun}"
                ToolTip.Tip="{Binding RunButtonToolTipText}">
          <AccessText Text="R_un" />
        </Button>
        <Button x:Name="StopButton" ToolTip.Tip="Cancel every execution this window currently has in flight.">
          <AccessText Text="_Stop" />
        </Button>
      </StackPanel>
      <TextBlock x:Name="RunStatusText" Text="{Binding RunStatusText}" />

      <!-- Needs-you first: the review gate's inline decisions, in plain words, before anything
           read-only. Same M15 commands, same semantics — Approve is Resume, Send back is
           Supersede (feedback file mandatory), Retry is RetryWithRevision (§17). -->
      <ItemsControl x:Name="PausedStepsList" ItemsSource="{Binding PausedSteps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PausedStepViewModel">
            <Border Classes="card needs-you" Margin="0,0,0,8">
              <StackPanel Spacing="{DynamicResource Space.3}">
                <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                  <Path Data="{StaticResource Icon.Dot}" Fill="{DynamicResource Status.NeedsYou}"
                        Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" />
                  <TextBlock Classes="heading" Text="{Binding StepId, StringFormat='Waiting for your review — {0}'}" />
                </StackPanel>
                <TextBlock Classes="caption" Text="{Binding Label}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <!-- #218: Approve/Retry/Reject reuse the status check/refresh/cross glyphs
                       already established (#206) — same shapes, same meaning, no new vocabulary. -->
                  <Button Classes="accent" Command="{Binding ApproveCommand}"
                          ToolTip.Tip="Accept this step's output and let the workflow continue.">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                      <Path Classes="action-icon" Data="{StaticResource Icon.Check}"
                            StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                            Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                      <AccessText Text="A_pprove" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding RetryCommand}"
                          ToolTip.Tip="Run this step again, optionally with your feedback file attached.">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                      <Path Classes="action-icon" Data="{StaticResource Icon.Refresh}"
                            StrokeThickness="1.4" StrokeLineCap="Round" StrokeJoin="Round"
                            Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                      <AccessText Text="_Retry this step" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding RejectCommand}"
                          ToolTip.Tip="End this step here — the workflow does not continue past it.">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                      <Path Classes="action-icon" Data="{StaticResource Icon.Cross}"
                            StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                            Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                      <AccessText Text="Re_ject" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <ItemsControl ItemsSource="{Binding SendBackTargets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SendBackTargetViewModel">
                        <Button Content="{Binding Label}" Command="{Binding SendBackCommand}"
                                ToolTip.Tip="Send the work back to an earlier step, with your feedback file — the feedback is what that step revises against." />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Feedback file:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding RevisionFilePath}" Width="260"
                           PlaceholderText="Optional for Retry, required to send back" />
                  <Button Content="Choose file…" Click="OnChooseFeedbackFileClick" />
                  <TextBlock Text="Worker:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding SupplementaryWorker}" Width="110" PlaceholderText="Worker role" />
                  <TextBlock Text="Output:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding SupplementaryOutputName}" Width="110" PlaceholderText="Output name" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="DecisionStatusText" Text="{Binding DecisionStatusText}" />

      <!-- The DAG, primary: click a node to open that step's drill-in. A bordered, dot-gridded
           canvas region (n8n/Dagster's convention, per design-language.md's reference set) gives
           the graph a defined surface instead of nodes floating loose on the page background. -->
      <Border BorderBrush="{DynamicResource Color.BorderSubtle}" BorderThickness="1"
              CornerRadius="{DynamicResource Radius.Medium}" ClipToBounds="True">
        <Panel Background="{DynamicResource Color.Surface}">
          <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
              <DrawingBrush TileMode="Tile" Stretch="None" DestinationRect="0,0,16,16" SourceRect="0,0,16,16">
                <DrawingBrush.Drawing>
                  <GeometryDrawing Brush="{DynamicResource Color.BorderSubtle}">
                    <GeometryDrawing.Geometry>
                      <EllipseGeometry Center="1,1" RadiusX="1" RadiusY="1" />
                    </GeometryDrawing.Geometry>
                  </GeometryDrawing>
                </DrawingBrush.Drawing>
              </DrawingBrush>
            </Rectangle.Fill>
          </Rectangle>
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="200" MaxHeight="360">
            <!-- Space.4 (16px) inlined for Margin — DynamicResource can't cross double->Thickness. -->
            <Canvas x:Name="DagCanvas" Margin="16" />
          </ScrollViewer>
        </Panel>
      </Border>

      <ItemsControl x:Name="StepChipsList" ItemsSource="{Binding TaskSteps}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StepItemViewModel">
            <Button Classes="card" Classes.selected="{Binding IsSelected}" Margin="0,0,8,8"
                    Command="{Binding SelectCommand}">
              <StackPanel Spacing="{DynamicResource Space.1}">
                <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
                  <Path Data="{Binding Status, Converter={StaticResource StatusToIconGeometryConverter}}"
                        Stroke="{Binding Status, Converter={StaticResource StatusToIconBrushConverter}}"
                        StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                        Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                  <TextBlock Classes="body-strong" Text="{Binding StepId}" />
                </StackPanel>
                <TextBlock Classes="caption" Text="{Binding PlainStatusText}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- The per-step drill-in: everything that used to sprawl as stacked sections, sliced to
           the selected step. -->
      <Border Classes="card" IsVisible="{Binding HasSelectedStep}">
        <StackPanel Spacing="8" DataContext="{Binding SelectedStep}" x:DataType="vm:StepItemViewModel">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Classes="heading" Text="{Binding StepId}" />
            <TextBlock Classes="secondary" Text="{Binding PlainStatusText}" VerticalAlignment="Center" />
            <TextBlock Classes="caption" Text="{Binding Worker, StringFormat='runner: {0}'}" VerticalAlignment="Center" />
          </StackPanel>
          <TabControl>
            <TabItem Header="Attempts">
              <ItemsControl x:Name="AttemptsList" ItemsSource="{Binding AttemptLines}" Margin="0,8,0,0" />
            </TabItem>
            <TabItem Header="Outputs">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="Nothing produced yet." IsVisible="{Binding !HasOutputFiles}" />
                <ItemsControl ItemsSource="{Binding OutputFiles}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ArtifactFileViewModel">
                      <Button Content="{Binding Label}" Command="{Binding PreviewCommand}"
                              Classes="chip" Classes.selected="{Binding IsSelected}" Margin="0,0,4,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox x:Name="ArtifactPreviewBox" IsReadOnly="True" AcceptsReturn="True"
                         TextWrapping="Wrap" Height="140" Classes="mono" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Conversation">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="No conversation recorded for this step." IsVisible="{Binding !HasConversations}" />
                <ItemsControl ItemsSource="{Binding Conversations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversationRefViewModel">
                      <Button Content="{Binding Label}" Command="{Binding ShowCommand}" Margin="0,0,4,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel x:Name="ConversationPanel" Spacing="6" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Decisions">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="No decisions recorded for this step." IsVisible="{Binding !HasDecisions}" />
                <ItemsControl x:Name="StepDecisionsList" ItemsSource="{Binding DecisionLines}" />
              </StackPanel>
            </TabItem>
          </TabControl>
        </StackPanel>
      </Border>

      <!-- Owner feedback: this rendered its heading with nothing underneath whenever nothing was
           actually running — hidden entirely rather than shown as an unexplained blank panel. -->
      <StackPanel Spacing="12" IsVisible="{Binding HasRunningExecutions}">
        <TextBlock Classes="heading" Text="Working right now — stop a single attempt:" />
        <ItemsControl x:Name="RunningExecutionsList" ItemsSource="{Binding RunningExecutions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:RunningExecutionViewModel">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Label}" Width="280" VerticalAlignment="Center" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <TextBlock Text="cancellation requested…" IsVisible="{Binding CancellationRequested}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="CancelStatusText" Text="{Binding CancelStatusText}" />
      </StackPanel>

      <!-- §12 traceability: the full, precise engine-level record — every fact the drill-in
           re-slices, in spec vocabulary, one disclosure away. Wrapped in a card (rather than
           templating Expander's own chrome, which has no BoxShadow property to target) so this
           gets the same elevation treatment as every other surface. Padding="0" (#220): Expander's
           own template already pads its content — the card's default 16px on top of that was
           double-padding the one surface in the view that's already the most content-dense. -->
      <Border Classes="card" Padding="0">
      <Expander Header="Details — the full record" IsExpanded="False">
        <!-- Space.3 (12px) — Thickness can't consume DynamicResource (see the card Padding
             comments elsewhere), so this stays inlined, but on the grid, not an arbitrary value. -->
        <StackPanel Spacing="{DynamicResource Space.3}" Margin="0,8,0,0">
          <TextBlock x:Name="StatusText" FontWeight="Bold" Text="No task directory loaded." />
          <StackPanel x:Name="StepsPanel" Spacing="{DynamicResource Space.1}" />

          <TextBlock Classes="heading" Text="Execution history:" />
          <StackPanel x:Name="HistoryPanel" Spacing="{DynamicResource Space.1}" />

          <TextBlock Classes="heading" Text="Conversation (executions with a durable transcript):" />
          <StackPanel x:Name="ConversationExecutionsPanel" Spacing="{DynamicResource Space.1}" />

          <TextBlock Classes="heading" Text="Recorded decisions:" />
          <StackPanel x:Name="DecisionsPanel" Spacing="{DynamicResource Space.1}" />

          <!-- #213: plain-language renames per docs/ux/ux-principles.md's vocabulary map — these
               stay one disclosure away (this Expander), so the precise spec terms survive in the
               tooltips/ids next to each entry, per the map's own "survives in disclosure
               surfaces" rule; only the section headers themselves needed to change. -->
          <TextBlock Classes="heading" Text="Extra runs — revised attempts and manually-supplied results:" />
          <StackPanel x:Name="SupplementaryPanel" Spacing="{DynamicResource Space.1}" />

          <TextBlock Classes="heading" Text="Output history — earlier versions of each file:" />
          <StackPanel x:Name="LineagePanel" Spacing="{DynamicResource Space.2}" />

          <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
            <TextBlock Text="Compare against:" VerticalAlignment="Center" />
            <TextBox x:Name="TemplateComparePathBox" Width="480" PlaceholderText="Workflow file to compare against (optional)" />
            <Button x:Name="CompareButton" Content="Compare to a workflow file" />
          </StackPanel>
          <TextBlock Classes="heading" Text="Changes vs. that workflow file:" />
          <StackPanel x:Name="DiffPanel" Spacing="{DynamicResource Space.1}" />
        </StackPanel>
      </Expander>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
