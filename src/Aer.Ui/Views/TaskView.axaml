<!-- M19 Phase 3 (#188): the Task view rebuilt human-first — needs-you first (inline decisions),
     then the DAG as the primary surface with per-step drill-in tabs (attempts / outputs /
     conversation / decisions), plain-language vocabulary throughout the primary text. The precise,
     complete engine-level record stays one disclosure away in the Details expander (§12
     traceability; ux-principles' progressive disclosure). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.TaskView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Classes="display" Text="{Binding TaskHeadlineText}" />
      <!-- The empty state says what to do next (Phase 5): nothing open, two ways forward. -->
      <TextBlock Classes="secondary" IsVisible="{Binding !HasSelectedStep}" TextWrapping="Wrap"
                 Text="Open a task from Home, or create and run a workflow in Author — this view fills in as soon as a task is open." />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="WorkflowTemplatePathBox" Width="300" PlaceholderText="Workflow file (fresh start only)" />
        <TextBox x:Name="BindingsFilePathBox" Width="300"
                 PlaceholderText="Who runs each step (bindings file)"
                 ToolTip.Tip="Pre-filled with the last-used bindings file as a convenience — always visible, always swappable, never remembered authority (§4)." />
        <Button x:Name="RunButton" Classes="accent" Content="Run" IsEnabled="{Binding !IsMutationInFlight}" />
        <Button x:Name="StopButton" Content="Stop" ToolTip.Tip="Cancel every execution this window currently has in flight (§9 host stop)." />
      </StackPanel>
      <TextBlock x:Name="RunStatusText" Text="{Binding RunStatusText}" />

      <!-- Needs-you first: the review gate's inline decisions, in plain words, before anything
           read-only. Same M15 commands, same semantics — Approve is Resume, Send back is
           Supersede (feedback file mandatory), Retry is RetryWithRevision (§17). -->
      <ItemsControl x:Name="PausedStepsList" ItemsSource="{Binding PausedSteps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PausedStepViewModel">
            <Border Classes="card needs-you" Margin="0,0,0,8">
              <StackPanel Spacing="8">
                <TextBlock Classes="heading" Text="{Binding StepId, StringFormat='Waiting for your review — {0}'}" />
                <TextBlock Classes="caption" Text="{Binding Label}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="accent" Content="Approve" Command="{Binding ApproveCommand}"
                          ToolTip.Tip="Resume: accept this step's output and let the workflow continue (§17)." />
                  <Button Content="Retry this step" Command="{Binding RetryCommand}"
                          ToolTip.Tip="RetryWithRevision: run this step again, optionally with your feedback file attached (§17)." />
                  <Button Content="Reject" Command="{Binding RejectCommand}"
                          ToolTip.Tip="Reject: end this step here — the workflow does not continue past it (§17)." />
                  <ItemsControl ItemsSource="{Binding SendBackTargets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SendBackTargetViewModel">
                        <Button Content="{Binding Label}" Command="{Binding SendBackCommand}"
                                ToolTip.Tip="Supersede: send the work back to an earlier step, with your feedback file — the feedback is what that step revises against (§17)." />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Feedback file:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding RevisionFilePath}" Width="260"
                           PlaceholderText="Optional for Retry, required to send back" />
                  <Button Content="Choose file…" Click="OnChooseFeedbackFileClick" />
                  <TextBox Text="{Binding SupplementaryWorker}" Width="110" PlaceholderText="Worker role" />
                  <TextBox Text="{Binding SupplementaryOutputName}" Width="110" PlaceholderText="Output name" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="DecisionStatusText" Text="{Binding DecisionStatusText}" />

      <!-- The DAG, primary: click a node to open that step's drill-in. -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="360">
        <Canvas x:Name="DagCanvas" />
      </ScrollViewer>

      <ItemsControl x:Name="StepChipsList" ItemsSource="{Binding TaskSteps}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StepItemViewModel">
            <Button Classes="card" Classes.selected="{Binding IsSelected}" Margin="0,0,8,8"
                    Command="{Binding SelectCommand}">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding StepId}" FontWeight="SemiBold" />
                <TextBlock Classes="caption" Text="{Binding PlainStatusText}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- The per-step drill-in: everything that used to sprawl as stacked sections, sliced to
           the selected step. -->
      <Border Classes="card" IsVisible="{Binding HasSelectedStep}">
        <StackPanel Spacing="8" DataContext="{Binding SelectedStep}" x:DataType="vm:StepItemViewModel">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Classes="heading" Text="{Binding StepId}" />
            <TextBlock Classes="secondary" Text="{Binding PlainStatusText}" VerticalAlignment="Center" />
            <TextBlock Classes="caption" Text="{Binding Worker, StringFormat='runner: {0}'}" VerticalAlignment="Center" />
          </StackPanel>
          <TabControl>
            <TabItem Header="Attempts">
              <ItemsControl x:Name="AttemptsList" ItemsSource="{Binding AttemptLines}" Margin="0,8,0,0" />
            </TabItem>
            <TabItem Header="Outputs">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="Nothing produced yet." IsVisible="{Binding !HasOutputFiles}" />
                <ItemsControl ItemsSource="{Binding OutputFiles}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ArtifactFileViewModel">
                      <Button Content="{Binding Label}" Command="{Binding PreviewCommand}" Margin="0,0,4,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox x:Name="ArtifactPreviewBox" IsReadOnly="True" AcceptsReturn="True"
                         TextWrapping="Wrap" Height="140" Classes="mono" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Conversation">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="No conversation recorded for this step." IsVisible="{Binding !HasConversations}" />
                <ItemsControl ItemsSource="{Binding Conversations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversationRefViewModel">
                      <Button Content="{Binding Label}" Command="{Binding ShowCommand}" Margin="0,0,4,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel x:Name="ConversationPanel" Spacing="6" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Decisions">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <TextBlock Classes="secondary" Text="No decisions recorded for this step." IsVisible="{Binding !HasDecisions}" />
                <ItemsControl x:Name="StepDecisionsList" ItemsSource="{Binding DecisionLines}" />
              </StackPanel>
            </TabItem>
          </TabControl>
        </StackPanel>
      </Border>

      <TextBlock Classes="heading" Text="Working right now — stop a single attempt (§7):" />
      <ItemsControl x:Name="RunningExecutionsList" ItemsSource="{Binding RunningExecutions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:RunningExecutionViewModel">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Label}" Width="280" VerticalAlignment="Center" />
              <Button Content="Cancel" Command="{Binding CancelCommand}" />
              <TextBlock Text="cancellation requested…" IsVisible="{Binding CancellationRequested}" VerticalAlignment="Center" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="CancelStatusText" Text="{Binding CancelStatusText}" />

      <!-- §12 traceability: the full, precise engine-level record — every fact the drill-in
           re-slices, in spec vocabulary, one disclosure away. -->
      <Expander Header="Details — the full record" IsExpanded="False">
        <StackPanel Spacing="12" Margin="0,8,0,0">
          <TextBlock x:Name="StatusText" FontWeight="Bold" Text="No task directory loaded." />
          <StackPanel x:Name="StepsPanel" Spacing="4" />

          <TextBlock Classes="heading" Text="Execution history:" />
          <StackPanel x:Name="HistoryPanel" Spacing="2" />

          <TextBlock Classes="heading" Text="Conversation (executions with a durable transcript — UI spec §10.1):" />
          <StackPanel x:Name="ConversationExecutionsPanel" Spacing="4" />

          <TextBlock Classes="heading" Text="Recorded decisions:" />
          <StackPanel x:Name="DecisionsPanel" Spacing="2" />

          <TextBlock Classes="heading" Text="Supplementary / human executions:" />
          <StackPanel x:Name="SupplementaryPanel" Spacing="2" />

          <TextBlock Classes="heading" Text="Artifact lineage:" />
          <StackPanel x:Name="LineagePanel" Spacing="6" />

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="TemplateComparePathBox" Width="480" PlaceholderText="Template path to compare against (optional)" />
            <Button x:Name="CompareButton" Content="Compare to template" />
          </StackPanel>
          <TextBlock Classes="heading" Text="Snapshot vs. template diff:" />
          <StackPanel x:Name="DiffPanel" Spacing="2" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
