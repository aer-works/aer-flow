<!-- M21 Phase 3 (issue #234): Enable Remote Access — the desktop half of pairing with Aer.Mobile.
     Aer.Daemon has no live rebind (Program.cs bakes the remote flag's bind address in at process
     start), so the toggle below is a real shutdown-and-respawn (RemoteViewModel.ToggleRemoteAsync),
     not an in-place setting flip — IsBusy covers that multi-second gap. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.RemoteView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="{DynamicResource Space.8}" MaxWidth="760" HorizontalAlignment="Left">
      <TextBlock Classes="display" Text="Remote Access" />

      <StackPanel Spacing="{DynamicResource Space.3}">
        <TextBlock Classes="secondary" TextWrapping="Wrap" Text="{Binding Remote.StatusText}" />
        <TextBlock Classes="secondary" Foreground="{DynamicResource Status.Failed}" TextWrapping="Wrap"
                   Text="{Binding Remote.ErrorText}" IsVisible="{Binding Remote.HasError}" />
        <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
          <Button x:Name="RemoteToggleButton" Classes="accent" HorizontalAlignment="Left"
                  Content="{Binding Remote.ToggleButtonText}" IsEnabled="{Binding !Remote.IsBusy}" />
          <!-- Toggling is a real shutdown-and-respawn (RemoteViewModel's own remarks), not an
               instant flip — found live that the button gave no feedback during that multi-second
               gap, so a click could look like it silently did nothing. -->
          <ProgressBar IsIndeterminate="True" Width="20" Height="20" VerticalAlignment="Center"
                       IsVisible="{Binding Remote.IsBusy}" />
        </StackPanel>
      </StackPanel>

      <!-- design-language.md: color never carries meaning alone — the plain-language warning is
           the actual signal, this border is just emphasis.
           IsVisible bound to ShowLanEncryptionWarning, true whenever remote access is on (issue
           #384): Aer.Daemon binds IPAddress.Any under the remote flag regardless of whether
           pairing is routed over the tailnet, so the plain-LAN listener stays reachable by anyone
           on the network the whole time remote is enabled. Previously gated on
           !IsPairingOverTailnet, which hid this warning exactly when a live QR was being offered. -->
      <Border Classes="card" BorderBrush="{DynamicResource Status.NeedsYou}"
              IsVisible="{Binding Remote.ShowLanEncryptionWarning}">
        <TextBlock Classes="secondary" TextWrapping="Wrap"
                    Text="While remote access is on, anyone on this network can reach Aer.Daemon — traffic isn't encrypted yet (that's planned for a later phase). Turn it off when you're done pairing." />
      </Border>

      <!-- M21 Phase 5 (#242): the Go tsnet sidecar Aer.Daemon spawns alongside the plain-LAN bind
           above. The four blocks below bind to CurrentSidecarPhase's derived booleans, which are
           mutually exclusive by construction (RemoteViewModel.CurrentSidecarPhase) — found live
           that binding each one to its own independent Has* flag let more than one render at once
           during in-between polls, instead of showing exactly one current state. -->
      <StackPanel Spacing="{DynamicResource Space.3}" IsVisible="{Binding Remote.IsRemoteEnabled}">
        <TextBlock Classes="heading" Text="Zero-config remote (Tailscale)" />

        <TextBlock Classes="secondary" TextWrapping="Wrap" IsVisible="{Binding Remote.IsSidecarStarting}"
                   Text="Starting..." />

        <StackPanel Spacing="{DynamicResource Space.2}" IsVisible="{Binding Remote.IsSidecarNeedsSignIn}">
          <TextBlock Classes="secondary" TextWrapping="Wrap"
                     Text="Sign in to Tailscale once to finish enabling zero-config remote access — no separate Tailscale app install needed." />
          <Button x:Name="RemoteOpenSidecarAuthButton" Classes="accent" HorizontalAlignment="Left" Content="Sign in to Tailscale" />
        </StackPanel>

        <StackPanel Spacing="{DynamicResource Space.2}" IsVisible="{Binding Remote.IsSidecarReadyPhase}">
          <!-- Doesn't claim "Pair a phone" below is now reachable from any network (issue #384):
               that section prefers the LAN address whenever this machine has one, so the tailnet
               address it also enables is Wi-Fi-independent reachability for an already-paired
               phone, not necessarily the address shown in the QR below. Full reconciliation of
               this messaging with LAN-vs-tailnet targeting folds into #338. -->
          <TextBlock Classes="secondary" TextWrapping="Wrap"
                     Text="Ready — this computer is now reachable over Tailscale from any network a paired phone has data on." />
          <!-- The only prior way to disconnect this node was deleting it from the Tailscale admin
               console and restarting Aer.Ui — found live via direct user feedback. Signs the sidecar
               out and immediately back into the interactive re-enrollment flow. -->
          <Button x:Name="RemoteForgetSidecarButton" HorizontalAlignment="Left"
                  IsEnabled="{Binding !Remote.IsBusy}" Content="Sign out of Tailscale" />
        </StackPanel>

        <TextBlock Classes="secondary" TextWrapping="Wrap"
                   IsVisible="{Binding Remote.IsSidecarUnavailable}" Text="{Binding Remote.SidecarError}" />
      </StackPanel>

      <!-- Single pairing target (Phase 5/6, #242/#243): EffectivePairingHost prefers this machine's
           LAN address whenever it has one, falling back to the sidecar's tailnet address only when
           it doesn't (issue #384 — a fresh phone can't reach the tailnet without an auth key, and
           the tailnet address isn't reliably reachable even with one). Found live that showing a
           second, separate Tailscale QR alongside this one was confusing (two QR codes, unclear
           which to scan), so there is now ever only one.
           Gated on IsRemoteEnabled (not merely HasEffectivePairingHost, issue #384): Host is
           populated by every refresh regardless of the toggle, so the old gate offered to pair a
           phone on a screen that, in the same breath, said remote access was off. -->
      <StackPanel Spacing="{DynamicResource Space.3}" IsVisible="{Binding Remote.ShowPairingBlock}">
        <TextBlock Classes="heading" Text="Pair a phone" />
        <TextBlock Classes="secondary" TextWrapping="Wrap"
                   Text="Open Aer.Mobile, scan this code (or type the host and code in by hand), and it's paired." />
        <TextBlock Classes="caption" IsVisible="{Binding Remote.IsPairingOverTailnet}"
                   Text="Via Tailscale — works from any network the phone has data on." />
        <TextBlock Classes="caption" IsVisible="{Binding !Remote.IsPairingOverTailnet}"
                   Text="Via local network — phone must be on the same Wi-Fi." />

        <!-- M21 Phase 7 follow-up (#246): a phone's embedded tsnet node needs a real Tailscale auth
             key on first enrollment — generate a reusable one in the Tailscale admin console
             (Settings -> Keys) once, paste it here, and it rides along in every QR from then on. -->
        <StackPanel Spacing="{DynamicResource Space.2}" IsVisible="{Binding Remote.IsPairingOverTailnet}">
          <TextBlock Classes="caption" Text="Tailscale auth key (lets a phone join without a browser sign-in)" />
          <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
            <TextBox x:Name="TailscaleAuthKeyBox" Width="360" PasswordChar="•"
                     Text="{Binding Remote.TailscaleAuthKey}" PlaceholderText="tskey-auth-..." />
            <Button x:Name="SaveTailscaleAuthKeyButton" IsEnabled="{Binding !Remote.IsBusy}" Content="Save" />
          </StackPanel>
          <TextBlock Classes="caption" Foreground="{DynamicResource Status.NeedsYou}" TextWrapping="Wrap"
                     IsVisible="{Binding Remote.NeedsTailscaleAuthKey}"
                     Text="No key saved yet — scanning this QR will fail on a phone with no prior Tailscale sign-in." />
        </StackPanel>

        <Border Classes="card" Width="240" Height="240" HorizontalAlignment="Left">
          <Image Source="{Binding Remote.QrPngBytes, Converter={StaticResource ByteArrayToBitmapConverter}}"
                 Width="220" Height="220" Stretch="Uniform" />
        </Border>
        <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.3}">
          <StackPanel Spacing="{DynamicResource Space.1}">
            <TextBlock Classes="caption" Text="Host" />
            <TextBlock Classes="mono" Text="{Binding Remote.EffectivePairingHost}" />
          </StackPanel>
          <StackPanel Spacing="{DynamicResource Space.1}">
            <TextBlock Classes="caption" Text="Pairing code" />
            <TextBlock Classes="mono body-strong" Text="{Binding Remote.PairingCode}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.2}">
          <!-- MinWidth pins the cell so "Expires in 60s" -> "Expires in 5s" doesn't reflow the
               button beside it every second as the digit count shrinks (found live). -->
          <TextBlock Classes="caption" VerticalAlignment="Center" MinWidth="90"
                     Text="{Binding Remote.PairingCodeExpiresInSeconds, StringFormat='Expires in {0}s'}" />
          <Button x:Name="RemoteRefreshCodeButton" IsEnabled="{Binding !Remote.IsBusy}">
            <AccessText Text="Get a new _code" />
          </Button>
        </StackPanel>
      </StackPanel>

      <!-- ShowPairingBlock's empty-state companion (issue #384): both require IsRemoteEnabled and
           are mutually exclusive on HasEffectivePairingHost, so exactly one of the two ever shows
           while remote access is on. -->
      <TextBlock Classes="secondary" TextWrapping="Wrap" IsVisible="{Binding Remote.ShowNoPairingHostMessage}"
                 Text="No network connection found — can't generate a pairing code until this computer is on a network." />

      <!-- Phase 6 (#243): PairedClientsStore could add a client but never remove one — this is the
           missing revocation path M20 deferred until "whichever milestone builds the actual remote
           client" (M21). -->
      <StackPanel Spacing="{DynamicResource Space.3}" IsVisible="{Binding Remote.HasPairedClients}">
        <TextBlock Classes="heading" Text="Paired devices" />
        <ItemsControl x:Name="PairedClientsList" ItemsSource="{Binding Remote.PairedClients}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PairedClientItemViewModel">
              <Border Classes="card" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Space.3}">
                  <StackPanel Spacing="{DynamicResource Space.1}" HorizontalAlignment="Stretch">
                    <TextBlock Classes="body-strong" Text="{Binding Name}" />
                    <TextBlock Classes="caption" Text="{Binding PairedAt, StringFormat='Paired {0:g}'}" />
                  </StackPanel>
                  <Button Content="Remove" Command="{Binding RemoveCommand}"
                          Foreground="{DynamicResource Status.Failed}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
