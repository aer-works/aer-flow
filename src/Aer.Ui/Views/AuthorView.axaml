<!-- M19 Phase 2 (#187): the Author view — the M16 template and worker-bindings editors, re-homed
     behavior-preserving (control names and semantics unchanged; Phase 4 rebuilds this into the
     guided, form-first New Workflow flow). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.AuthorView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Classes="display" Text="Author" />

      <TextBlock Classes="heading" Text="Template editor (create or edit a template file — never a bound task, §5):" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="TemplateEditorPathBox" Width="360" PlaceholderText="Template file to edit / save to" />
        <Button x:Name="NewTemplateButton" Content="New template" />
        <Button x:Name="EditTemplateButton" Content="Open in editor" />
        <Button x:Name="SaveTemplateButton" Content="Save" IsEnabled="{Binding TemplateEditor.IsDirty}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Text="{Binding TemplateEditor.TemplateId}" Width="300"
                 PlaceholderText="WorkflowTemplateId" IsEnabled="{Binding TemplateEditor.IsOpen}" />
        <TextBox Text="{Binding TemplateEditor.TemplateVersionText}" Width="120"
                 PlaceholderText="Version" IsEnabled="{Binding TemplateEditor.IsOpen}" />
      </StackPanel>
      <TextBlock x:Name="TemplateEditorStatusText" Text="{Binding TemplateEditor.StatusText}" />

      <TextBlock Classes="heading" Text="Steps (§8 — add/remove, edit fields, choose DependsOn from declared steps):" />
      <Button x:Name="AddStepButton" Content="Add step" IsEnabled="{Binding TemplateEditor.IsOpen}" />
      <ItemsControl x:Name="StepsEditorList" ItemsSource="{Binding TemplateEditor.Steps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StepEditorViewModel">
            <Border Classes="card" Margin="0,0,0,8">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBox Text="{Binding StepId}" Width="140" PlaceholderText="StepId" />
                  <TextBox Text="{Binding Worker}" Width="140" PlaceholderText="Worker" />
                  <TextBox Text="{Binding MaxAttemptsText}" Width="90" PlaceholderText="MaxAttempts" />
                  <Button Content="Remove" Command="{Binding RemoveCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBox Text="{Binding InputsText}" Width="220" PlaceholderText="Inputs (comma-separated)" />
                  <TextBox Text="{Binding OutputsText}" Width="220" PlaceholderText="Outputs (comma-separated)" />
                </StackPanel>
                <TextBlock Text="Depends on:" />
                <ItemsControl ItemsSource="{Binding DependsOnOptions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DependsOnOptionViewModel">
                      <CheckBox Content="{Binding StepId}" IsChecked="{Binding IsSelected}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <CheckBox Content="Pause point" IsChecked="{Binding HasPausePoint}" />
                <StackPanel IsVisible="{Binding HasPausePoint}" Spacing="4">
                  <TextBlock Text="Supersede targets (this step's transitive ancestors):" />
                  <ItemsControl ItemsSource="{Binding SupersedeTargetOptions}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SupersedeTargetOptionViewModel">
                        <CheckBox Content="{Binding StepId}" IsChecked="{Binding IsSelected}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Classes="heading" Text="Validation (empty = the current edit may be saved):" />
      <ItemsControl x:Name="TemplateValidationErrorsList" ItemsSource="{Binding TemplateEditor.ValidationErrors}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <TextBlock Text="{Binding}" Foreground="{DynamicResource Status.Failed}" TextWrapping="Wrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Classes="heading" Text="Template preview graph (re-layouts on every structural edit):" />
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="280">
        <Canvas x:Name="TemplateEditorDagCanvas" />
      </ScrollViewer>

      <TextBlock Classes="heading" Text="Worker-bindings editor (create or edit a bindings file — §9; never persisted in a task directory):" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="BindingsEditorPathBox" Width="360" PlaceholderText="Bindings file to edit / save to" />
        <Button x:Name="NewBindingsButton" Content="New bindings" />
        <Button x:Name="EditBindingsButton" Content="Open in editor" />
        <Button x:Name="SaveBindingsButton" Content="Save" IsEnabled="{Binding BindingsEditor.IsDirty}" />
        <Button x:Name="AddBindingEntryButton" Content="Add entry" IsEnabled="{Binding BindingsEditor.IsOpen}" />
        <Button x:Name="CheckBindingsAgainstTemplateButton" Content="Check against open template" IsEnabled="{Binding BindingsEditor.IsOpen}" />
      </StackPanel>
      <ItemsControl x:Name="BindingEntriesList" ItemsSource="{Binding BindingsEditor.Entries}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:WorkerBindingEntryViewModel">
            <Border Classes="card" Margin="0,0,0,8">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBox Text="{Binding WorkerName}" Width="150" PlaceholderText="Worker role name" />
                  <ComboBox ItemsSource="{Binding AdapterCandidates}" Text="{Binding Adapter}" IsEditable="True"
                            Width="120" PlaceholderText="Adapter" />
                  <TextBox Text="{Binding Model}" Width="150" PlaceholderText="Model (optional)" />
                  <TextBox Text="{Binding PermissionScope}" Width="150" PlaceholderText="Permission scope (optional)" />
                  <TextBox Text="{Binding TimeoutText}" Width="90" PlaceholderText="Timeout (hh:mm:ss)" />
                  <Button Content="Remove" Command="{Binding RemoveCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBox Text="{Binding ContractWorkerName}" Width="150" PlaceholderText="Contract WorkerName" />
                  <TextBox Text="{Binding RequiredInputsText}" Width="200" PlaceholderText="Required inputs (comma-separated)" />
                  <TextBox Text="{Binding OptionalMetadataText}" Width="200" PlaceholderText="Optional metadata (comma-separated)" />
                </StackPanel>
                <TextBox Text="{Binding PromptTemplate}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" PlaceholderText="Prompt template" />
                <TextBox Text="{Binding ProducedOutputsJson}" AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                         Classes="mono" PlaceholderText="Produced outputs (raw JSON array)" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="Template workers with no binding entry (advisory only, never a save gate):" />
      <ItemsControl x:Name="MissingBindingsPanel" ItemsSource="{Binding BindingsEditor.MissingTemplateWorkerNames}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
      <TextBlock x:Name="BindingsEditorStatusText" Text="{Binding BindingsEditor.StatusText}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
