<!-- M19 Phase 2 (#187): the Author view — the M16 template and worker-bindings editors, re-homed
     behavior-preserving (control names and semantics unchanged; Phase 4 rebuilds this into the
     guided, form-first New Workflow flow). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aer.Ui.Core;assembly=Aer.Ui.Core"
             x:Class="Aer.Ui.Views.AuthorView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Classes="display" Text="Create a workflow" />

      <!-- M19 Phase 4 (#189): the guided flow — form-first, no typed paths, no raw JSON; saving
           writes the same durable files the advanced editors below edit by hand. -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Name:" VerticalAlignment="Center" />
            <TextBox Text="{Binding NewWorkflow.WorkflowName}" Width="240" PlaceholderText="e.g. draft-and-review" />
            <TextBlock Text="Saved in:" VerticalAlignment="Center" Classes="secondary" />
            <TextBlock x:Name="WorkspacePathText" Text="{Binding NewWorkflow.EffectiveWorkspacePath}"
                       VerticalAlignment="Center" Classes="caption" />
            <Button Content="Change folder…" Click="OnChooseWorkspaceClick" />
          </StackPanel>

          <ItemsControl x:Name="VendorReadinessList" ItemsSource="{Binding NewWorkflow.VendorReadinessLines}" />

          <!-- M21 Phase 1 follow-up: permissions are set once per workflow, not once per step — a
               builder on every step card doesn't scale, and burying it in the Advanced bindings
               editor made it invisible to anyone on the guided (primary) path. Applies to every
               Claude/Gemini step at Save; dialogue steps are unaffected (their participants' own
               permissions come from DialogueParticipantPresets). -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Permissions (applies to every Claude/Gemini step):" VerticalAlignment="Center" Classes="secondary" />
            <CheckBox Content="Read files" IsChecked="{Binding NewWorkflow.GrantReadFiles}" />
            <CheckBox Content="Write files" IsChecked="{Binding NewWorkflow.GrantWriteFiles}" />
            <CheckBox Content="Run shell commands" IsChecked="{Binding NewWorkflow.GrantRunShellCommands}" />
            <TextBox Text="{Binding NewWorkflow.ShellCommandPatternsText}" Width="150" PlaceholderText="Command patterns (e.g. git:*)"
                     IsVisible="{Binding NewWorkflow.ShowShellCommandPatterns}" />
            <CheckBox Content="Network access" IsChecked="{Binding NewWorkflow.GrantNetworkAccess}" />
          </StackPanel>
          <TextBlock Classes="caption" Text="Leave unchecked to use each runner's own default permissions." />

          <Button Command="{Binding NewWorkflow.AddStepCommand}"><AccessText Text="Ad_d a step" /></Button>
          <ItemsControl x:Name="GuidedStepsList" ItemsSource="{Binding NewWorkflow.Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:GuidedStepViewModel">
                <Border Classes="card" Margin="0,0,0,8">
                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="Name:" VerticalAlignment="Center" />
                      <TextBox Text="{Binding Name}" Width="160" />
                      <ComboBox ItemsSource="{Binding KindOptions}" SelectedItem="{Binding Kind}" Width="120" />
                      <TextBlock Text="Produces:" VerticalAlignment="Center" />
                      <TextBox Text="{Binding ProducesFileName}" Width="180" PlaceholderText="(file name)" />
                      <TextBlock Text="Model:" VerticalAlignment="Center" />
                      <TextBox Text="{Binding Model}" Width="160" PlaceholderText="(optional)" />
                      <CheckBox Content="Review gate" IsChecked="{Binding HasReviewGate}"
                                ToolTip.Tip="Pause here for your review before the workflow continues — approve, retry, send back, or reject." />
                      <Button Content="Remove" Command="{Binding RemoveCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="Runs after:" VerticalAlignment="Center" />
                      <ItemsControl ItemsSource="{Binding DependsOnOptions}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:GuidedDependsOnOptionViewModel">
                            <CheckBox Content="{Binding StepName}" IsChecked="{Binding IsSelected}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                    <TextBlock Text="Prompt:" IsVisible="{Binding !IsDialogue}" />
                    <TextBox Text="{Binding Prompt}" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                             PlaceholderText="What should this step's runner do?" IsVisible="{Binding !IsDialogue}" />
                    <StackPanel Spacing="4" IsVisible="{Binding IsDialogue}">
                      <TextBlock Text="Opening prompt:" />
                      <TextBox Text="{Binding SeedPrompt}" AcceptsReturn="True" TextWrapping="Wrap" Height="40"
                               PlaceholderText="What the conversation is about" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Turns:" VerticalAlignment="Center" />
                        <TextBox Text="{Binding TurnBudgetText}" Width="80" />
                        <TextBlock Text="Claude's instructions:" VerticalAlignment="Center" />
                        <TextBox Text="{Binding InitiatorPreamble}" Width="260" />
                        <TextBlock Text="Gemini's instructions:" VerticalAlignment="Center" />
                        <TextBox Text="{Binding ResponderPreamble}" Width="260" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Owner feedback: liked the guidance concept but found it "hard to parse — just lots of
               text." Every line rendered in Status.NeedsYou (the loudest color in the system,
               design-language.md's status table) regardless of whether it was a real blocker or
               just "give it a name" on a form nobody has filled in yet — an empty form starts with
               two guidance lines by construction, so the loudest color in the app was the very
               first thing a new user saw, and it stayed that loud as more lines stacked up while
               filling the form in normally. Secondary/caption styling with a plain dash marker
               reads as gentle in-progress hints, matching what these actually are (Validate() has
               no severity tier — they're all the same kind of "not done yet" fact). -->
          <ItemsControl x:Name="GuidanceList" ItemsSource="{Binding NewWorkflow.GuidanceMessages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <TextBlock Classes="caption" Text="{Binding StringFormat='— {0}'}" TextWrapping="Wrap" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding NewWorkflow.SaveCommand}"><AccessText Text="_Save" /></Button>
            <Button Classes="accent" Command="{Binding NewWorkflow.SaveAndRunCommand}"><AccessText Text="Save and _run" /></Button>
            <TextBlock x:Name="NewWorkflowStatusText" Text="{Binding NewWorkflow.StatusText}" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- #219: hidden by default — the raw template/bindings editors used to sit permanently
           visible below the guided flow, one long scrollable list mixing a beginner path with an
           expert one with no signal about which to use. Collapsed here (Padding="0": Expander
           already pads its content, see the same reasoning on TaskView's Details expander), the
           guided card above is unambiguously the primary, default path. -->
      <Border Classes="card" Padding="0">
      <Expander Header="Advanced — edit the files directly" IsExpanded="False">
      <StackPanel Spacing="{DynamicResource Space.3}" Margin="16,8,16,16">
      <TextBlock Classes="heading" Text="Template editor (create or edit a template file — never a bound task):" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Template file:" VerticalAlignment="Center" />
        <TextBox x:Name="TemplateEditorPathBox" Width="360" />
        <Button x:Name="NewTemplateButton" Content="New template" />
        <Button x:Name="EditTemplateButton" Content="Open in editor" />
        <Button x:Name="SaveTemplateButton" Content="Save" IsEnabled="{Binding TemplateEditor.IsDirty}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Template ID:" VerticalAlignment="Center" />
        <TextBox Text="{Binding TemplateEditor.TemplateId}" Width="300"
                 IsEnabled="{Binding TemplateEditor.IsOpen}" />
        <TextBlock Text="Version:" VerticalAlignment="Center" />
        <TextBox Text="{Binding TemplateEditor.TemplateVersionText}" Width="120"
                 IsEnabled="{Binding TemplateEditor.IsOpen}" />
      </StackPanel>
      <TextBlock x:Name="TemplateEditorStatusText" Text="{Binding TemplateEditor.StatusText}" />

      <StackPanel Spacing="{DynamicResource Space.3}" IsVisible="{Binding TemplateEditor.IsOpen}">
      <TextBlock Classes="heading" Text="Steps (add/remove, edit fields, choose which steps each one depends on):" />
      <Button x:Name="AddStepButton" Content="Add step" IsEnabled="{Binding TemplateEditor.IsOpen}" />
      <ItemsControl x:Name="StepsEditorList" ItemsSource="{Binding TemplateEditor.Steps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StepEditorViewModel">
            <Border Classes="card" Margin="0,0,0,8">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Step ID:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding StepId}" Width="140" />
                  <TextBlock Text="Worker:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Worker}" Width="140" />
                  <TextBlock Text="Max attempts:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding MaxAttemptsText}" Width="90" />
                  <Button Content="Remove" Command="{Binding RemoveCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Inputs:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding InputsText}" Width="220" PlaceholderText="(comma-separated)" />
                  <TextBlock Text="Outputs:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding OutputsText}" Width="220" PlaceholderText="(comma-separated)" />
                </StackPanel>
                <TextBlock Text="Depends on:" />
                <ItemsControl ItemsSource="{Binding DependsOnOptions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DependsOnOptionViewModel">
                      <CheckBox Content="{Binding StepId}" IsChecked="{Binding IsSelected}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- #213: matches the guided flow's own "Review gate" wording above (AuthorView's
                     M19 Phase 4 addition already used the vocabulary map — this M16 advanced
                     editor predates that phase and had not been caught up until now). -->
                <CheckBox Content="Review gate" IsChecked="{Binding HasPausePoint}" />
                <StackPanel IsVisible="{Binding HasPausePoint}" Spacing="4">
                  <TextBlock Text="Steps you can send back to:" />
                  <ItemsControl ItemsSource="{Binding SupersedeTargetOptions}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:SupersedeTargetOptionViewModel">
                        <CheckBox Content="{Binding StepId}" IsChecked="{Binding IsSelected}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Classes="heading" Text="Validation (empty = the current edit may be saved):" />
      <ItemsControl x:Name="TemplateValidationErrorsList" ItemsSource="{Binding TemplateEditor.ValidationErrors}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <TextBlock Text="{Binding}" Foreground="{DynamicResource Status.Failed}" TextWrapping="Wrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Classes="heading" Text="Template preview graph (re-layouts on every structural edit):" />
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="280">
        <Canvas x:Name="TemplateEditorDagCanvas" />
      </ScrollViewer>
      </StackPanel>

      <TextBlock Classes="heading" Text="Worker-bindings editor (create or edit a bindings file — never persisted in a task directory):" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Bindings file:" VerticalAlignment="Center" />
        <TextBox x:Name="BindingsEditorPathBox" Width="360" />
        <Button x:Name="NewBindingsButton" Content="New bindings" />
        <Button x:Name="EditBindingsButton" Content="Open in editor" />
        <Button x:Name="SaveBindingsButton" Content="Save" IsEnabled="{Binding BindingsEditor.IsDirty}" />
        <Button x:Name="AddBindingEntryButton" Content="Add entry" IsEnabled="{Binding BindingsEditor.IsOpen}" />
        <Button x:Name="CheckBindingsAgainstTemplateButton" Content="Check against open template" IsEnabled="{Binding BindingsEditor.IsOpen}" />
      </StackPanel>
      <StackPanel Spacing="{DynamicResource Space.3}" IsVisible="{Binding BindingsEditor.IsOpen}">
      <ItemsControl x:Name="BindingEntriesList" ItemsSource="{Binding BindingsEditor.Entries}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:WorkerBindingEntryViewModel">
            <Border Classes="card" Margin="0,0,0,8">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Worker name:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding WorkerName}" Width="150" />
                  <TextBlock Text="Adapter:" VerticalAlignment="Center" />
                  <ComboBox ItemsSource="{Binding AdapterCandidates}" Text="{Binding Adapter}" IsEditable="True"
                            Width="120" />
                  <TextBlock Text="Model:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Model}" Width="150" PlaceholderText="(optional)" />
                  <TextBlock Text="Timeout:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding TimeoutText}" Width="90" PlaceholderText="(hh:mm:ss)" />
                  <Button Content="Remove" Command="{Binding RemoveCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Contract name:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding ContractWorkerName}" Width="150" />
                  <TextBlock Text="Required inputs:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding RequiredInputsText}" Width="200" PlaceholderText="(comma-separated)" />
                  <TextBlock Text="Optional metadata:" VerticalAlignment="Center" />
                  <TextBox Text="{Binding OptionalMetadataText}" Width="200" PlaceholderText="(comma-separated)" />
                </StackPanel>
                <!-- M21 Phase 1 (permission-scope model): the builder is the default, primary path
                     (Blank rows start here) — four grant categories plus a shell-command pattern
                     allowlist, translated per-vendor by ClaudeWorkerAdapter/GeminiWorkerAdapter.
                     "Advanced" switches to the pre-existing raw PermissionScope text box for vendor
                     vocabulary the structured model can't express yet. -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Permissions:" VerticalAlignment="Center" />
                  <CheckBox Content="Advanced (raw)" IsChecked="{Binding IsAdvancedPermissionScope}" />
                  <TextBox Text="{Binding PermissionScope}" Width="220" IsVisible="{Binding IsAdvancedPermissionScope}"
                           PlaceholderText="(raw, vendor-specific)" />
                  <CheckBox Content="Read files" IsChecked="{Binding GrantReadFiles}" IsVisible="{Binding !IsAdvancedPermissionScope}" />
                  <CheckBox Content="Write files" IsChecked="{Binding GrantWriteFiles}" IsVisible="{Binding !IsAdvancedPermissionScope}" />
                  <CheckBox Content="Run shell commands" IsChecked="{Binding GrantRunShellCommands}" IsVisible="{Binding !IsAdvancedPermissionScope}" />
                  <TextBox Text="{Binding ShellCommandPatternsText}" Width="150" PlaceholderText="Command patterns (e.g. git:*)"
                           IsVisible="{Binding ShowShellCommandPatterns}" />
                  <CheckBox Content="Network access" IsChecked="{Binding GrantNetworkAccess}" IsVisible="{Binding !IsAdvancedPermissionScope}" />
                </StackPanel>
                <TextBlock Text="{Binding PermissionGrantGapWarning}" TextWrapping="Wrap"
                           Foreground="{DynamicResource Status.Failed}" IsVisible="{Binding HasPermissionGrantGapWarning}" />
                <TextBlock Text="Prompt template:" />
                <TextBox Text="{Binding PromptTemplate}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" />
                <TextBlock Text="Produced outputs (raw JSON array):" />
                <TextBox Text="{Binding ProducedOutputsJson}" AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                         Classes="mono" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="Template workers with no binding entry (advisory only, never a save gate):" />
      <ItemsControl x:Name="MissingBindingsPanel" ItemsSource="{Binding BindingsEditor.MissingTemplateWorkerNames}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
      </StackPanel>
      <TextBlock x:Name="BindingsEditorStatusText" Text="{Binding BindingsEditor.StatusText}" />
      </StackPanel>
      </Expander>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
