<Project>

  <!-- release-please linked-versions migration: Aer.Ui is one of "desktop" group's two shipped,
       version-checked-against-each-other artifacts (alongside Aer.Daemon — TaskSession compares the
       daemon's reported assembly version against the UI's to detect a stale spawned daemon), so it
       carries the real, release-please-patched Version. Aer.Ui.Core stays on the root file's static
       Version; nothing reads its own assembly version independently. Imports the root file first for
       shared settings, then overrides just Version. -->
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))"/>

  <PropertyGroup>
    <Version>0.20.0</Version>
  </PropertyGroup>

</Project>
