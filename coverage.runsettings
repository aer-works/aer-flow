<?xml version="1.0" encoding="utf-8"?>
<!-- Coverage collection settings (#199), consumed by the `coverage` pixi task. Source-generated
     code (CommunityToolkit.Mvvm partials, Avalonia XAML codegen, regex generators) is excluded by
     attribute — it would misreport the hand-written surface's coverage in both directions. -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
