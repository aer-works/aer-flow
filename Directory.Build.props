<Project>

  <!-- M13 Phase 2 (#108) set this up as the repo's single shared version; the release-please
       linked-versions migration (two groups — "core": Aer.Flow/Aer.Adapters/Aer.Workers.Dialogue/
       Aer.Cli, "desktop": Aer.Ui.Core/Aer.Ui/Aer.Daemon — see release-please-config.json) moved real,
       release-please-patched versioning onto each group's shipped artifact's own local
       Directory.Build.props (Aer.Cli's, Aer.Ui's, Aer.Daemon's). This root Version is now just the
       static default every other project (Aer.Flow, Aer.Adapters, Aer.Workers.Dialogue, Aer.Ui.Core)
       inherits — none of them are independently packed/shipped, so nothing reads their own assembly
       version, and it no longer needs to move on its own. -->
  <PropertyGroup>
    <Version>0.14.0</Version>

    <!-- The SDK defaults to appending "+<git-sha>" to AssemblyInformationalVersion, which would make
         `aer`'s version flag output ("0.7.0+<sha>") never match CHANGELOG.md's plain "0.7.0" entry —
         exactly what this phase's produced-artifact requirement rules out. -->
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
  </PropertyGroup>

</Project>
